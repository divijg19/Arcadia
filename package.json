{
  "name": "arcadia",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "arcadia-ts"
  ],
  "scripts": {
    "dev": "wasm-pack build arcadia-rs --target web && cd arcadia-ts && bun run dev",
    "test": "bun run test:rs",
    "test:rs": "cd arcadia-rs && cargo test",
    "format": "bun run format:rs && bun run format:ts",
    "format:rs": "cd arcadia-rs && cargo fmt --all",
    "format:ts": "cd arcadia-ts && bun run format",
    "lint": "bun run lint:rs && bun run lint:ts",
    "lint:rs": "cd arcadia-rs && cargo clippy --all -- -D warnings",
    "lint:ts": "cd arcadia-ts && bun run lint"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@biomejs/biome": "^2.4.7"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}