# Arcadia top-level .gitignore

# -----------------------
# 1) Operating System
# -----------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------
# 2) Node / Bun / JavaScript
# -----------------------
node_modules/
**/node_modules/
# Keep lockfiles (bun.lock, package-lock.json, yarn.lock) committed for reproducible installs

# -----------------------
# 3) Build output
# -----------------------
dist/
dist-ssr/
out/
build/
*.tgz

# -----------------------
# 4) Coverage reports
# -----------------------
coverage/
*.lcov

# -----------------------
# 5) Logs
# -----------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------
# 6) Environment
# -----------------------
.env
.env.*.local
.env.local
*.local

# -----------------------
# 7) Tooling caches / intermediate files
# -----------------------
.cache/
.vite/
.vitecache/
.eslintcache
*.tsbuildinfo

# -----------------------
# 8) WASM / Rust build outputs
# -----------------------
# Ignore wasm-pack generated JS/WASM package (generated build artifact)
arcadia-rs/pkg/
# Rust target directories
arcadia-rs/target/
target/
**/target/
# For library crates, Cargo.lock is optional; ignore arcadia-rs/Cargo.lock to avoid noise
arcadia-rs/Cargo.lock

# -----------------------
# 9) IDEs, editors and temp files
# -----------------------
# Keep shared editor files out of the repo but allow committed workspace extensions
.vscode/*
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project
*.swp
*.sw?
*~
*.bak
*.suo
*.ntvs*
*.njsproj
*.sln

# -----------------------
# 10) Misc
# -----------------------
# (Add other machine-specific files below as needed)
