# Arcadia top-level .gitignore

# -----------------------
# Operating System
# -----------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------
# Node / Bun / JavaScript
# -----------------------
node_modules/
**/node_modules/
# Keep lockfiles (bun.lock, package-lock.json, yarn.lock) committed for reproducible installs

# -----------------------
# Build output
# -----------------------
dist/
dist-ssr/
out/
build/
*.tgz
**/node_modules
**/.DS_Store
**/dist
**/dist-ssr
**/*.local
**/.env
**/.nitro
**/.tanstack
**/.wrangler
**/.output
**/.vinxi
**/__unconfig*


# -----------------------
# Coverage reports
# -----------------------
coverage/
*.lcov

# -----------------------
# Logs
# -----------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------
# Environment
# -----------------------
.env
.env.*.local
.env.local
*.local

# -----------------------
# Tooling caches / intermediate files
# -----------------------
.cache/
.vite/
.vitecache/
.eslintcache
*.tsbuildinfo

# -----------------------
# WASM / Rust build outputs
# -----------------------
# Ignore wasm-pack generated `pkg/` directories (JS glue, .wasm, etc.).
# We intentionally *do not* ignore committed declaration files or package.json in those
# directories; those may be checked in for editor/type support.
packages/*/pkg/
!packages/*/pkg/*.d.ts
!packages/*/pkg/package.json
!packages/*/pkg/*.d.ts

# Also ignore any crate-local `pkg/` output produced by wasm-pack
**/pkg/

# Rust target directories (build artifacts)
**/target/

# Ignore per-crate Cargo.lock files (keep top-level Cargo.lock if you use it)
Cargo.lock
**/Cargo.lock

# If you have a specific engine crate named `arcadia-rs` keep an exception for
# hand-maintained files in its pkg/ directory while ignoring generated files:
arcadia-rs/pkg/
!arcadia-rs/pkg/*.d.ts
!arcadia-rs/pkg/package.json
arcadia-rs/target/

# -----------------------
# IDEs, editors and temp files
# -----------------------
# Keep shared editor files out of the repo but allow committed workspace extensions
.vscode/*
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project
*.swp
*.sw?
*~
*.bak
*.suo
*.ntvs*
*.njsproj
*.sln

# -----------------------
# Misc
# -----------------------
# (Add other machine-specific files below as needed)
